            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-web</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-security</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-tenant</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-governance</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-mybatis</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-cache</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-mq</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-protection</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-storage</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-log</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-dict</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-sensitive</artifactId>
                <version>${zen.version}</version>
            </dependency>

            <dependency>
                <groupId>com.kxqd.zen</groupId>
                <artifactId>zen-infra-crypto</artifactId>
